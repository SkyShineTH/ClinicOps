# Non-secret local defaults for ClinicOps / clinic-demo.
# Copy to .env.local for npm-based development, or export values before Docker Compose.

# Optional. When unset, booking and staff demo data use in-memory storage.
DATABASE_URL=

# Optional PostgreSQL tuning used only when DATABASE_URL is set.
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_IDLE_TIMEOUT_SECONDS=20
DATABASE_POOL_MAX=5
DATABASE_SSL=false

# Optional. Required for staff mutation endpoints when NODE_ENV=production.
# Use a real secret in deployed environments; do not commit it.
STAFF_API_TOKEN=

# Docker Compose host port overrides.
APP_PORT=3000
POSTGRES_PORT=5433
POSTGRES_DB=clinicops
POSTGRES_USER=clinicops
POSTGRES_PASSWORD=clinicops_dev_password

# Smoke script target for an already-running app.
SMOKE_BASE_URL=http://localhost:3000
